{
  "name": "react-native-runtimes-root",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "example": "bun --cwd example",
    "example:android": "bun --cwd example android",
    "example:ios": "bun --cwd example ios",
    "example:start": "bun --cwd example start",
    "lint": "bun --cwd example lint",
    "test": "bun --cwd example test"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
